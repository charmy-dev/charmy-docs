#: ../../../charmy/charmy/utils/geo_math.py:docstring of charmy.utils.geo_math.evaluate_quadratic_bezier:1
msgid "Evaluate a quadratic Bezier at parameter t (0..1)."
msgstr ""

#: ../../../charmy/charmy/utils/geo_math.py:docstring of charmy.utils.geo_math.evaluate_quadratic_bezier:3
msgid "Returns (x, y) as floats."
msgstr ""

#: ../../../charmy/charmy/utils/geo_math.py:docstring of charmy.utils.geo_math.quadratic_bezier_internal_t_roots:1
msgid "Return the list of unique t roots (0<t<1) where derivative in x or y is zero."
msgstr ""

#: ../../../charmy/charmy/utils/geo_math.py:docstring of charmy.utils.geo_math.quadratic_bezier_internal_t_roots:3
msgid "This mirrors solving (p0 - 2*p1 + p2) * t = (p0 - p1) for each coordinate."
msgstr ""

#: ../../../charmy/charmy/utils/geo_math.py:docstring of charmy.utils.geo_math.evaluate_cubic_bezier:1
msgid "Evaluate a cubic Bezier at parameter t (0..1). Returns (x, y) floats."
msgstr ""

#: ../../../charmy/charmy/utils/geo_math.py:docstring of charmy.utils.geo_math.cubic_bezier_derivative_roots:1
msgid "Return t roots (0<t<1) where derivative in x or y is zero."
msgstr ""

#: ../../../charmy/charmy/utils/geo_math.py:docstring of charmy.utils.geo_math.cubic_bezier_derivative_roots:3
msgid "Solves quadratic 3*a t^2 + 2*b t + c = 0 for each coordinate, where a = -p0 + 3*p1 - 3*p2 + p3 b = 3*(p0 - 2*p1 + p2) c = 3*(p1 - p0)"
msgstr ""

#: ../../../charmy/charmy/utils/geo_math.py:docstring of charmy.utils.geo_math.gui_deg_to_math_rad:1
