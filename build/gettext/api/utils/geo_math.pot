msgstr ""

#: ../../../charmy/charmy/utils/geo_math.py:docstring of charmy.utils.geo_math.gui_deg_to_math_rad:3
msgid "This follows the conversion used in the original shape code."
msgstr ""

#: ../../../charmy/charmy/utils/geo_math.py:docstring of charmy.utils.geo_math.point_on_circle:1
